# ============================================================
# CofRe — backend/.env.example
# Copie para backend/.env e preencha com seus dados reais
# NUNCA commite o .env real no GitHub
# ============================================================

PORT=3001
DB_HOST=localhost
DB_USER=root
DB_PASS=SUA_SENHA_MYSQL
DB_NAME=cofre_senhas
# Se o Railway usar porta diferente da 3306:
# DB_PORT=3306

JWT_SECRET=GERE_COM: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
FRONTEND_URL=http://localhost:5173

# ── EFÍ Bank (Pix) ──────────────────────────────────────────
# Pegar em: app.sejaefi.com.br → API → Aplicações → Produção
EFI_CLIENT_ID=SEU_CLIENT_ID
EFI_CLIENT_SECRET=SEU_CLIENT_SECRET

# Desenvolvimento: usa arquivo local
EFI_CERT_PATH=./certificado.p12

# Produção (Render/Railway): usa base64
# Execute: node -e "console.log(require('fs').readFileSync('./certificado.p12').toString('base64'))"
EFI_CERT_B64=

EFI_PIX_KEY=SUA_CHAVE_PIX_ALEATORIA
EFI_SANDBOX=false

# ── Planos (valores em reais) ────────────────────────────────
PRECO_ACESSO=2.00
PRECO_MENSAL=34.90
PRECO_ANUAL=299.00
INATIVIDADE_MINUTOS=5

# ── Admin TOTP ───────────────────────────────────────────────
# Configure em: https://cofre-backend.onrender.com/api/admin/totp-setup
ADMIN_TOTP_SECRET=
# Use senha forte em produção (mínimo 16 chars)
ADMIN_SENHA=MUDE_ISSO_EM_PRODUCAO
