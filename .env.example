# ============================================================
# .env.example — CofRe
# Copie este arquivo para .env e preencha com seus dados
# NUNCA commite o .env real no GitHub
# ============================================================

PORT=3001
DB_HOST=localhost
DB_USER=root
DB_PASS=SUA_SENHA_MYSQL_AQUI
DB_NAME=cofre_senhas
JWT_SECRET=GERE_UMA_FRASE_ALEATORIA_LONGA_AQUI
FRONTEND_URL=http://localhost:5173

# ── EFÍ Bank (Pix) ─────────────────────────────────────────
# Pegue estas credenciais em: app.sejaefi.com.br → API → Aplicações
EFI_CLIENT_ID=SEU_CLIENT_ID_AQUI
EFI_CLIENT_SECRET=SEU_CLIENT_SECRET_AQUI
EFI_CERT_PATH=./certificado.p12
EFI_PIX_KEY=SUA_CHAVE_PIX_AQUI
# Use 'true' para testes, 'false' para produção real
EFI_SANDBOX=false

# ── Regras de cobrança ──────────────────────────────────────
PRECO_ACESSO=0.30
INATIVIDADE_MINUTOS=5
